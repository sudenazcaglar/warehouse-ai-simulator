# Project
PROJECT_NAME=warehouse-ai-simulator
ENVIRONMENT=development

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
DASHBOARD_PORT=3000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=warehouse_ai
POSTGRES_USER=warehouse_user
POSTGRES_PASSWORD=warehouse_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=models

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_me

# Streaming
STREAMING_MODE=hls
STREAM_HOST=localhost
STREAM_PORT=8080

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# Nginx
NGINX_PORT=8080